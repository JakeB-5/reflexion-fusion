{
  "name": "reflexion-fusion",
  "version": "0.2.0",
  "description": "Skill-Creator + Reflexion fusion plugin for Claude Code — automatic skill lifecycle",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
